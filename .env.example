# Email address to receive form submissions
CONTACT_EMAIL=example@email.com

# OAuth2 Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_EMAIL=example@email.com

# Search Console / Webmaster Tools verification (optional)
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=

# Translation for ARBs: `dart run tool/translate_arb.dart` (then `dart run slang` runs inside the tool).
# TRANSLATION_PROVIDER=openai   # default: slang_gpt → OpenAI
# TRANSLATION_PROVIDER=ollama   # local: Ollama HTTP API (no OPENAI_API_KEY)
OPENAI_API_KEY=
# Optional defaults when not passing CLI args after `--`:
# SLANG_GPT_TARGET=es
# SLANG_GPT_FULL=true

# Ollama (when TRANSLATION_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_MAX_BATCH_CHARS=6000
# OLLAMA_SYSTEM=You are a professional UI translator...
